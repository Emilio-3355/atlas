# Server
NODE_ENV=production
PORT=3000
BASE_URL=https://atlas-xxxxx.up.railway.app

# Database (Railway PostgreSQL)
DATABASE_URL=postgresql://...

# Redis (Railway Redis)
REDIS_URL=redis://...

# Anthropic (THE BRAIN)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (embeddings + image generation only)
OPENAI_API_KEY=sk-...

# Twilio (WhatsApp)
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_WHATSAPP_NUMBER=+1...

# JP's phone (the ONLY authorized user)
JP_PHONE_NUMBER=+1...

# Gmail (OAuth2)
GMAIL_CLIENT_ID=...
GMAIL_CLIENT_SECRET=...
GMAIL_REDIRECT_URI=https://atlas-xxxxx.up.railway.app/auth/google/callback
GMAIL_REFRESH_TOKEN=...

# Brave Search
BRAVE_SEARCH_API_KEY=...

# Logging
LOG_LEVEL=info
